{
  "name": "goose-testing",
  "version": "1.0.0",
  "description": "Test suite for Goose project",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint test/**/*.js",
    "lint:fix": "eslint test/**/*.js --fix"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "eslint": "^8.56.0",
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "lib/**/*.js",
      "src/**/*.js",
      "!**/node_modules/**"
    ],
    "testMatch": [
      "**/test/**/*.test.js",
      "**/test/**/*.spec.js"
    ]
  },
  "babel": {
    "presets": ["@babel/preset-env"]
  }
}